          <Layout class="org.netbeans.modules.form.compat2.layouts.support.JScrollPaneSupportLayout"/>
          <SubComponents>
            <Component class="javax.swing.JTextArea" name="txtRules">
              <Properties>
                <Property name="columns" type="int" value="20"/>
                <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
                  <Font name="Segoe UI" size="12" style="1"/>
                </Property>
                <Property name="rows" type="int" value="5"/>
                <Property name="text" type="java.lang.String" value="&#xa;1. Answer Correctly: Players must answereach riddle correctly to&#xa;proceed to the next level.&#xa;2. Time Limit: Players have a limited amount of time to answer&#xa;each riddle. If they fail to answer within the time limit, the game ends.&#xa;3. Hint Usage: Players can use hints to help them answer a riddle.&#xa;However, hints are limited and must be used wisely.&#xa;4. Level Progression: Players must complete all riddles in a level to&#xa;unlock the next level. Each level contains more challenging riddles.&#xa;5. Scoring: Players earn hint coin for each correct answer within 20 &#xa;seconds.&#xa;6. Game Over: If players answer a riddle incorrectly or run out of&#xa;time, the game ends. They can choose to play again or return&#xa;to the main menu.&#xa;7. Hint Coins: Players can earn hint coins by answering riddles quickly.&#xa;These coins can be used to purchase hints in later levels.&#xa;"/>
              </Properties>
            </Component>
          </SubComponents>
        </Container>
